# Feature Flags
# Set to 'true' to use mock/hardcoded users (no real authentication)
# Set to 'false' or remove to use real Supabase authentication
VITE_MOCK_USER_MODE=true

# API Mode — set to 'mock' to bypass real auth and use hardcoded dev sessions
VITE_API_MODE=mock

# Clerk (frontend)
# Get your publishable key from https://dashboard.clerk.com
VITE_CLERK_PUBLISHABLE_KEY=pk_test_...

# Database
DATABASE_URL="postgresql://..."

# Clerk webhook secret (backend)
CLERK_WEBHOOK_SECRET=""

# Resend API key (backend — for welcome emails)
